# FTIAS Development Environment Variables
# Copy this file to .env and update with your values

# ======================
# Database Configuration
# ======================
POSTGRES_DB=ftias_db
POSTGRES_USER=ftias_user
POSTGRES_PASSWORD=ftias_password
POSTGRES_PORT=5432

# ======================
# Backend Configuration
# ======================
BACKEND_PORT=8000
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production-minimum-32-characters
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ======================
# Frontend Configuration
# ======================
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:8000
NODE_ENV=development

# ======================
# pgAdmin Configuration (Optional)
# ======================
PGADMIN_EMAIL=admin@ftias.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# ======================
# JWT Configuration
# ======================
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ======================
# File Upload Configuration
# ======================
MAX_UPLOAD_SIZE=100  # MB
ALLOWED_EXTENSIONS=csv,xlsx,xls

# ======================
# AI Document Processing
# ======================
EMBEDDING_BATCH_SIZE=32
DOCLING_NUM_THREADS=4
DOCLING_FAST_MODE=false
DOCLING_AUTO_FAST_FOR_LARGE_FILES=true
DOCLING_FAST_THRESHOLD_MB=25
DOCLING_TABLE_STRUCTURE=true
DOCLING_MAX_CHUNK_CHARS=5000

# ======================
# AI Query Answer Quality
# ======================
LLM_MODEL=gpt-4o-mini
QUERY_LLM_MODEL=gpt-4o-mini
QUERY_TOP_K_DEFAULT=8
QUERY_CONTEXT_LIMIT=12
QUERY_MIN_UNIQUE_DOCUMENTS=3
QUERY_MAX_CHUNKS_PER_DOCUMENT=3
QUERY_VECTOR_CANDIDATES=30
QUERY_LEXICAL_CANDIDATES=20
QUERY_MAX_TOKENS=1800
QUERY_TEMPERATURE=0.1
QUERY_MIN_CITATION_DENSITY=0.6
QUERY_WARNING_CITATION_DENSITY=0.4
QUERY_STRICT_CITATIONS=true
ANALYSIS_LLM_MODEL=gpt-4o-mini
ANALYSIS_MAX_TOKENS=2600
ANALYSIS_TEMPERATURE=0.2
ANALYSIS_MIN_CITATION_DENSITY=0.75

# ======================
# Logging Configuration
# ======================
LOG_LEVEL=INFO
LOG_FORMAT=json
